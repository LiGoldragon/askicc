;; Pattern.synth — inside match arm (...)
;;
;; Or-patterns use | between variants in source: (Fire | Air).
;; The match arm handles the | separation at the Match level,
;; not inside Pattern.

;; variant with binding: (Ident @Name)
// @Variant _@_@Binding

;; bare variant: (Fire)
// @Variant

;; string literal: ("(")
// "literal"
