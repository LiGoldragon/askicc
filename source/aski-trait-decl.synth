;; aski-trait-decl.synth — inside (camelName/ [...])
;;
;; (describe/ [(describe/ :@Self Quality)])
;; (compute/ [(add/ :@Self U32) (multiply/ :@Self @Factor U32 U32)])

(CtxKind/ TraitDecl SignatureList SigParams)

/

(LBracket TraitDecl/ SignatureList Space)
;; [(sigs)] — signature list inside trait decl

(LParen SignatureList camelName/ SigParams Space)
;; (describe/ :@Self Quality) — one method signature
