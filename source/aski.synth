;; aski.synth — the aski dialect
;;
;; All six delimiters used at root:
;;   ()    Module, Domain, TraitDecl
;;   []    TraitImpl
;;   {}    Struct
;;   {||}  Const
;;   (||)  Ffi
;;   [||]  Process (inline executable)

(@Module/ <module>)

*(@Domain/ <domain>)
*(@trait/ <trait-decl>)

*[@trait/ <trait-impl>]

*{@Struct/ <struct>}

*{|@Const/ :Type @value|}

*(|@Ffi/ <ffi>|)

?[|<process>|]
