;; param.synth — method/signature parameters
;;
;; :@Self           → immutable borrow of Self
;; ~@Self           → mutable borrow of Self
;; @Self            → owned Self
;; :@Name           → immutable borrow (type inferred)
;; ~@Name           → mutable borrow (type inferred)
;; @Name :Type      → named param with explicit type
;; @Name            → owned param (type inferred)

// _:@_Self
// _~@_Self
// _@_Self
// _:@_@name
// _~@_@name
// _@_@name :Type
// _@_@name
