;; SynthLabel.synth — @Name, :Name, or 'Name
;;
;; Three bindings: Declare (@), Reference (:), Origin (').
;; Origin is always PascalCase (places are PascalCase instances).

// #DeclarePascal#_@_@LabelName
// #DeclareCamel#_@_@labelName
// #ReferencePascal#_:_:LabelName
// #ReferenceCamel#_:_:labelName
// #OriginPascal#_'_@PlaceName
